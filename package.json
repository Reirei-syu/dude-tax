{
  "name": "dude-tax",
  "version": "0.1.0",
  "private": true,
  "main": "apps/desktop/electron/main.cjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:api": "npm run build --workspace @dude-tax/api",
    "dev": "concurrently -k \"npm run dev --workspace @dude-tax/api\" \"npm run dev --workspace @dude-tax/desktop\"",
    "build:desktop": "npm run build --workspace @dude-tax/desktop",
    "package:win": "npm run build:api && npm run build:desktop && node scripts/package-win.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "concurrently": "^9.2.1"
  }
}
