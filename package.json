{
  "name": "dude-tax",
  "version": "0.1.0-alpha",
  "private": true,
  "main": "apps/desktop/electron/main.cjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:api": "npm run build --workspace @dude-tax/api",
    "dev": "concurrently -k \"npm run dev --workspace @dude-tax/api\" \"npm run dev --workspace @dude-tax/desktop\"",
    "build:desktop": "npm run build --workspace @dude-tax/desktop",
    "package:installer": "node scripts/build-installer.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "package:win": "npm run build:api && npm run build:desktop && node scripts/package-win.mjs",
    "release:win": "npm run package:win && npm run package:installer",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "concurrently": "^9.2.1",
    "lint-staged": "^16.2.3",
    "prettier": "^3.6.2"
  }
}
